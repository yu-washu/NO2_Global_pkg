#!/bin/bash
#BSUB -n 2
#BSUB -q general
#BSUB -R "rusage[mem=16GB] span[hosts=1] select[gpuhost]"
#BSUB -G compute-rvmartin
#BSUB -W 0:30
#BSUB -gpu "num=1"
#BSUB -a 'docker(1yuyan/lightgbm-cuda:v3)'
#BSUB -J "Test_CUDA_LightGBM"
#BSUB -N
#BSUB -u yany1@wustl.edu
#BSUB -o logs-v0.2.0/Test_CUDA_LightGBM-%J-output.txt

mkdir -p logs-v0.2.0

cd /my-projects2/1.project/NO2_DL_global/NO2_global_pkg
. /opt/conda/bin/activate

echo "========================================================================"
echo "Testing CUDA-enabled LightGBM Docker Image"
echo "========================================================================"
echo ""

echo "1. GPU Information:"
echo "--------------------------------------------------------------------"
nvidia-smi || echo "No nvidia-smi available"
echo ""

echo "2. LightGBM Version and Build Info:"
echo "--------------------------------------------------------------------"
python -c "
import lightgbm as lgb
print(f'LightGBM version: {lgb.__version__}')
print(f'Installation path: {lgb.__file__}')
"
echo ""

echo "3. Quick GPU Test (minimal dataset):"
echo "--------------------------------------------------------------------"
python << 'EOF'
import lightgbm as lgb
import numpy as np

# Create tiny test dataset
np.random.seed(42)
X = np.random.rand(1000, 10)
y = np.random.rand(1000)

train_data = lgb.Dataset(X, label=y)

# Try to train with GPU
params = {
    'objective': 'regression',
    'device': 'cuda',
    'verbose': 1,
    'num_leaves': 31,
    'num_iterations': 10
}

print("\n🧪 Attempting GPU training with device='cuda'...")
try:
    model = lgb.train(params, train_data, num_boost_round=10)
    print("✅ SUCCESS! CUDA training completed!")
except Exception as e:
    print(f"❌ FAILED: {e}")
    print("\nTrying with device='gpu'...")
    params['device'] = 'gpu'
    try:
        model = lgb.train(params, train_data, num_boost_round=10)
        print("✅ GPU training worked!")
    except Exception as e2:
        print(f"❌ GPU also failed: {e2}")
EOF

echo ""
echo "========================================================================"
echo "Test completed: $(date)"
echo "========================================================================"
